@0              CMP     #$37DE,D1
                BHS.S   @1
                MOVE.B  (A4,D1.L),D0
                SUBQ.B  #1,D0
                MOVE    CCR,D3
                OR.B    (DECFlags,PC,D3),D5
                JMP     (A0)
@1              BSR     MEMRead
                SUBQ.B  #1,D0
                MOVE    CCR,D3
                OR.B    (DECFlags,PC,D3),D5
