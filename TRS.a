	#$00,(FDCData,A5)		MOVE.L	#NIL,(RWPtr,A5)		MOVE	#0,(RWCount,A5)		RTS		ENDP;ččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččč; pascal void Z80Run(short count);;čččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččZ80RUN		PROC	ENTRYStackFrame	RECORD	{A6Link},DECRParamBegin	EQU	*count		DS.W	1ParamSize	EQU	ParamBegin-*RetAddr		DS.L	1A6Link		DS.L	1LocalSize	EQU	*		ENDR		WITH	Globals,StackFrame		LINK	A6,#LocalSize		MOVEM.L	D3-D7/A2-A4,-(SP)		MOVE	(count,A6),(reg.IC,A5)		MOVEQ	#0,D7		MOVEQ	#0,D6		MOVEQ	#0,D5		MOVEQ	#0,D4		MOVEQ	#0,D3		MOVEQ	#0,D2		MOVEQ	#0,D1		MOVEQ	#0,D0		MOVE	(reg.PC,A5),D7		MOVE	(reg.SP,A5),D6		MOVE.B	(reg.F,A5),D5		MOVE.B	(reg.A,A5),D4		MOVE.L	(memory,A5),A4		MOVE.L	(opTable,A5),A3		LEA	(@0,PC),A0		TST.B	(Z80NMIFlag,A5)		BNE	NMI@0		SUBQ	#1,(reg.IC,A5)		BCS.S	@1		TST.B	(Z80INTFlag,A5)		BNE	INT		MOVE	(A4,D7.L),D0		JMP	([A3,D0.L*4])@1		MOVE.B	D4,(reg.A,A5)		MOVE.B	D5,(reg.F,A5)		MOVE	D6,(reg.SP,A5)		MOVE	D7,(reg.PC,A5)Exit		MOVEM.L	(SP)+,D3-D7/A2-A4		UNLK	A6		RTD	#ParamSize		ENDP;ččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččč; End of Z80-CPU Emulator;ččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččč; Routine name	MEMRead;; On entry	A4: memory (pointer);		D1: address (long word)			; $0000-$FFFF;; On exit	D0: data (byte);čččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččMEMREAD		FUNC	ENTRY		WITH	Globals		CMP	#$3C00,D1		BLO.S	@0		MOVE.B	(A4,D1.L),D0		RTS@0		CMP	#$37DE,D1		BHS.S	@1		MOVE.B	#$FF,D0		RTS@1		CMP	#$3800,D1		BLO.S	@5		MOVEM.L	D1/A0,-(SP)		LEA	(trsKeys,A5),A0		CLR.B	D0		BRA.S	@4@2		LSR.B	#1,D1		BCC.S	@3		OR.B	(A0),D0@3		ADDQ.L	#1,A0@4		TST.B	D1		BNE.S	@2		MOVEM.L	(SP)+,D1/A0		RTS@5		MOVEM.L	D0/D1,-(SP)		SUB	#$37DE,D1		MOVE	(@6,PC,D1*2),D1		JMP	(@6,PC,D1)@6		DC.W	@7-@6		; $37DE		DC.W	@7-@6		; $37DF		DC.W	M37E0-@6	; $37E0		DC.W	M37E0-@6	; $37E1		DC.W	M37E0-@6	; $37E2		DC.W	M37E0-@6	; $37E3		DC.W	@7-@6		; $37E4		DC.W	@7-@6		; $37E5		DC.W	@7-@6		; $37E6		DC.W	@7-@6		; $37E7		DC.W	@7-@6		; $37E8		DC.W	@7-@6		; $37E9		DC.W	@7-@6		; $37EA		DC.W	@7-@6		; $37EB		DC.W	M37EC-@6	; $37EC		DC.W	M37ED-@6	; $37ED		DC.W	M37EE-@6	; $37EE		DC.W	M37EF-@6	; $37EF		DC.W	M37E0-@6	; $37F0		DC.W	M37E0-@6	; $37F1		DC.W	M37E0-@6	; $37F2		DC.W	M37E0-@6	; $37F3		DC.W	@7-@6		; $37F4		DC.W	@7-@6		; $37F5		DC.W	@7-@6		; $37F6		DC.W	@7-@6		; $37F7		DC.W	@7-@6		; $37F8		DC.W	@7-@6		; $37F9		DC.W	@7-@6		; $37FA		DC.W	@7-@6		; $37FB		DC.W	M37EC-@6	; $37FC		DC.W	M37ED-@6	; $37FD		DC.W	M37EE-@6	; $37FE		DC.W	M37EF-@6	; $37FF@7		MOVEM.L	(SP)+,D0/D1		MOVE.B	#$FF,D0		RTSM37E0		MOVEM.L	(SP)+,D0/D1		MOVE.B	(IntLatch,A5),D0		AND.B	#$3F,(IntLatch,A5)		RTSM37EC		TST.B	(driveSelect,A5)		; FDC Status Register		BNE.S	@0		TST.L	(diskSize+0,A5)		BNE.S	@1		MOVEM.L	(SP)+,D0/D1		MOVE.B	#$FF,D0		RTS@0		MOVE.L	(Ticks),D0		SUB.L	(driveTime,A5),D0		CMP.L	#3*60,D0		BLO.S	@2		CLR.B	(driveSelect,A5)@1		MOVEM.L	(SP)+,D0/D1		MOVE.B	#$80,D0		RTS@2		CMP.B	#1,(driveSelect,A5)		BNE.S	@3		TST.L	(diskSize+0,A5)		BNE.S	@10		BRA.S	@4@3		CMP.B	#2,(driveSelect,A5)		BNE.S	@4		TST.L	(diskSize+4,A5)		BNE.S	@10@4		MOVEM.L	(SP)+,D0/D1		MOVE.B	#$00,D0		RTS@10		MOVE.B	(FDCState,A5),D0		BNE.S	@20		MOVE.B	(diskIndex,A5),D2		TST.B	(FDCTrack,A5)		BNE.S	@11		OR.B	#$04,D2@11		CMP.B	#1,(driveSelect,A5)		BNE.S	@12		TST.B	(diskProtect+0,A5)		BEQ.S	@14		BRA.S	@13@12		TST.B	(diskProtect+1,A5)		BEQ.S	@14@13		OR.B	#$40,D2@14		MOVEM.L	(SP)+,D0/D1		MOVE.B	D2,D0		RTS@20		SUBQ.B	#1,D0		BNE.S	@30		TST	(RWCount,A5)		BEQ.S	@21		MOVE.B	#$03,D2		BRA.S	@22@21		MOVE.B	#$00,D2		CMP.B	#$11,(FDCTrack,A5)		BNE.S	@22		OR.B	#$20,D2@22		MOVEM.L	(SP)+,D0/D1		MOVE.B	D2,D0		RTS@30		SUBQ.B	#1,D0		BNE.S	@40		CMP.B	#1,(driveSelect,A5)		BNE.S	@31		TST.B	(diskProtect+0,A5)		BEQ.S	@33		BRA.S	@32@31		TST.B	(diskProtect+1,A5)		BEQ.S	@33@32		MOVE.B	#$40,D2		BRA.S	@35@33		TST	(RWCount,A5)		BEQ.S	@34		MOVE.B	#$03,D2		BRA.S	@35@34		MOVE.B	#$00,D2@35		MOVEM.L	(SP)+,D0/D1		MOVE.B	D2,D0		RTS@40		MOVEM.L	(SP)+,D0/D1		MOVE.B	#$04,D0		RTSM37ED		MOVEM.L	(SP)+,D0/D1			; FDC Track Register		MOVE.B	(FDCTrack,A5),D0		RTSM37EE		MOVEM.L	(SP)+,D0/D1			; FDC Sector Register		MOVE.B	(FDCSector,A5),D0		RTSM37EF		CMP.B	#1,(FDCState,A5)		; FDC Data Register		BNE.S	@0		TST	(RWCount,A5)		BEQ.S	@0		TST.B	(driveSelect,A5)		BEQ.S	@0		MOVE.L	(RWPtr,A5),A2		MOVE.B	(A2)+,(FDCData,A5)		MOVE.L	A2,(RWPtr,A5)		SUBQ	#1,(RWCount,A5)@0		MOVEM.L	(SP)+,D0/D1		MOVE.B	(FDCData,A5),D0		RTS		ENDF;ččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččč; Routine name	MEMWrite;; On entry	A4: memory (pointer);		D0: data (byte);		D1: address (long word)			; $0000-$FFFF;čččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččMEMWRITE	PROC	ENTRY		WITH	Globals		CMP	#$3C00,D1		BLO.S	@0		MOVE.B	D0,(A4,D1.L)		RTS@0		CMP	#$37DE,D1		BHS.S	@1		RTS@1		CMP	#$3800,D1		BLO.S	@2		RTS@2		MOVEM.L	D0/D1,-(SP)		SUB	#$37DE,D1		MOVE	(@3,PC,D1*2),D1		JMP	(@3,PC,D1)@3		DC.W	@4-@3		; $37DE		DC.W	@4-@3		; $37DF		DC.W	M37E1-@3	; $37E0		DC.W	M37E1-@3	; $37E1		DC.W	M37E1-@3	; $37E2		DC.W	M37E1-@3	; $37E3		DC.W	@4-@3		; $37E4		DC.W	@4-@3		; $37E5		DC.W	@4-@3		; $37E6		DC.W	@4-@3		; $37E7		DC.W	@4-@3		; $37E8		DC.W	@4-@3		; $37E9		DC.W	@4-@3		; $37EA		DC.W	@4-@3		; $37EB		DC.W	M37EC-@3	; $37EC		DC.W	M37ED-@3	; $37ED		DC.W	M37EE-@3	; $37EE		DC.W	M37EF-@3	; $37EF		DC.W	M37E1-@3	; $37F0		DC.W	M37E1-@3	; $37F1		DC.W	M37E1-@3	; $37F2		DC.W	M37E1-@3	; $37F3		DC.W	@4-@3		; $37F4		DC.W	@4-@3		; $37F5		DC.W	@4-@3		; $37F6		DC.W	@4-@3		; $37F7		DC.W	@4-@3		; $37F8		DC.W	@4-@3		; $37F9		DC.W	@4-@3		; $37FA		DC.W	@4-@3		; $37FB		DC.W	M37EC-@3	; $37FC		DC.W	M37ED-@3	; $37FD		DC.W	M37EE-@3	; $37FE		DC.W	M37EF-@3	; $37FF@4		MOVEM.L	(SP)+,D0/D1		RTSM37E1		MOVEM.L	(SP)+,D0/D1			; Disk Drive Select Latch		MOVE.B	D0,(driveSelect,A5)		MOVE.L	(Ticks),(driveTime,A5)		RTSM37EC		LSR.B	#3,D0				; FDC Command Register		AND	#$001E,D0		MOVE	(@0,PC,D0),D0		JMP	(@0,PC,D0)@0		DC.W	Restore-@0	; $00		DC.W	Seek-@0		; $10		DC.W	Step-@0		; $20		DC.W	Step-@0		; $30		DC.W	StepIn-@0	; $40		DC.W	StepIn-@0	; $50		DC.W	StepOut-@0	; $60		DC.W	StepOut-@0	; $70		DC.W	ReadCmd-@0	; $80		DC.W	ReadCmd-@0	; $90		DC.W	WriteCmd-@0	; $A0		DC.W	WriteCmd-@0	; $B0		DC.W	ReadAddr-@0	; $C0		DC.W	ForceInt-@0	; $D0		DC.W	ReadTrack-@0	; $E0		DC.W	WriteTrack-@0	; $F0Restore		MOVEM.L	(SP)+,D0/D1		TST.B	(driveSelect,A5)		BEQ.S	@0		MOVE.B	#0,(FDCTrack,A5)		MOVE.B	#0,(FDCState,A5)@0		RTSSeek		MOVEM.L	(SP)+,D0/D1		TST.B	(driveSelect,A5)		BEQ.S	@0		MOVE.B	(FDCData,A5),(FDCTrack,A5)		MOVE.B	#0,(FDCState,A5)@0		RTSStep		MOVEM.L	(SP)+,D0/D1		MOVE.B	#0,(FDCState,A5)		RTSStepIn		MOVEM.L	(SP)+,D0/D1		MOVE.B	#0,(FDCState,A5)		RTSStepOut		MOVEM.L	(SP)+,D0/D1		MOVE.B	#0,(FDCState,A5)		RTSReadCmd		MOVEM.L	(SP)+,D0/D1		MOVEQ	#0,D0		MOVE.B	(FDCTrack,A5),D0		MULU	#10,D0		MOVE.B	(FDCSector,A5),D2		ADD.L	D2,D0		LSL.L	#8,D0		CMP.B	#1,(driveSelect,A5)		BNE.S	@0		CMP.L	(diskSize+0,A5),D0		BHS.S	@2		ADD.L	(diskBuff+0,A5),D0		BRA.S	@1@0		CMP.B	#2,(driveSelect,A5)		BNE.S	@3		CMP.L	(diskSize+4,A5),D0		BHS.S	@2		ADD.L	(diskBuff+4,A5),D0@1		MOVE.L	D0,(RWPtr,A5)		MOVE	#256,(RWCount,A5)		MOVE.B	#1,(FDCState,A5)@2		MOVEQ	#0,D0@3		RTSWriteCmd	MOVEM.L	(SP)+,D0/D1		MOVEQ	#0,D0		MOVE.B	(FDCTrack,A5),D0		MULU	#10,D0		MOVE.B	(FDCSector,A5),D2		ADD.L	D2,D0		LSL.L	#8,D0		CMP.B	#1,(driveSelect,A5)		BNE.S	@0		CMP.L	(diskSize+0,A5),D0		BHS.S	@2		ADD.L	(diskBuff+0,A5),D0		BRA.S	@1@0		CMP.B	#2,(driveSelect,A5)		BNE.S	@3		CMP.L	(diskSize+4,A5),D0		BHS.S	@2		ADD.L	(diskBuff+4,A5),D0@1		MOVE.L	D0,(RWPtr,A5)		MOVE	#256,(RWCount,A5)		MOVE.B	#2,(FDCState,A5)@2		MOVEQ	#0,D0@3		RTSReadAddr	MOVEM.L	(SP)+,D0/D1		MOVE.B	#3,(FDCState,A5)		RTSReadTrack	MOVEM.L	(SP)+,D0/D1		MOVE.B	#3,(FDCState,A5)		RTSWriteTrack	MOVEM.L	(SP)+,D0/D1		MOVE.B	#3,(FDCState,A5)		RTSForceInt	MOVEM.L	(SP)+,D0/D1		MOVE.B	#0,(FDCState,A5)		RTSM37ED		MOVEM.L	(SP)+,D0/D1			; FDC Track Register		MOVE.B	D0,(FDCTrack,A5)		RTSM37EE		MOVEM.L	(SP)+,D0/D1			; FDC Sector Register		MOVE.B	D0,(FDCSector,A5)		RTSM37EF		MOVEM.L	(SP)+,D0/D1			; FDC Data Register		MOVE.B	D0,(FDCData,A5)		CMP.B	#2,(FDCState,A5)		BNE.S	@2		TST	(RWCount,A5)		BEQ.S	@2		CMP.B	#1,(driveSelect,A5)		BNE.S	@0		TST.B	(diskProtect+0,A5)		BNE.S	@2		ST	(diskDirty+0,A5)		BRA.S	@1@0		CMP.B	#2,(driveSelect,A5)		BNE.S	@2		TST.B	(diskProtect+1,A5)		BNE.S	@2		ST	(diskDirty+1,A5)@1		MOVE.L	(RWPtr,A5),A2		MOVE.B	(FDCData,A5),(A2)+		MOVE.L	A2,(RWPtr,A5)		SUBQ	#1,(RWCount,A5)@2		RTS		ENDP;ččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččč; Routine name	Timer0Task;; On entry	A1: Address of the task record (pointer);čččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččTIMER0TASK	PROC	ENTRY		WITH	Globals,TMInfo		MOVE.L	A5,-(SP)		MOVE.L	(tmRefCon,A1),A5		OR.B	#$80,(IntLatch,A5)		TST.B	(INTMaster,A5)		BNE.S	@0		MOVE.L	#1,(ICount,A5)		BRA.S	@1@0		ADDQ.L	#1,(ICount,A5)		TST.B	(IFF1,A5)		BEQ.S	@1		ST	(Z80INTFlag,A5)@1		MOVE.L	A1,A0		MOVEQ	#25,D0		_PrimeTimeExit		MOVE.L	(SP)+,A5		RTS		ENDP;ččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččč; Routine name	Timer1Task;; On entry	A1: Address of the task record (pointer);čččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččTIMER1TASK	PROC	ENTRY		WITH	Globals,TMInfo		MOVE.L	A5,-(SP)		MOVE.L	(tmRefCon,A1),A5		BCHG	#1,(diskIndex,A5)		BEQ.S	@0		MOVE.L	#195,D0		BRA.S	@1@0		MOVE.L	#005,D0@1		MOVE.L	A1,A0		_PrimeTimeExit		MOVE.L	(SP)+,A5		RTS		ENDP;ččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččč; pascal void StartTimers(void);;čččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččSTARTTIMERS	PROC	ENTRY		WITH	Globals,TMInfo,TMTask		LEA	(timer0,A5),A0		LEA	Timer0Task,A1		MOVE.L	A1,(tmAddr,A0)		CLR.L	(tmCount,A0)		CLR.L	(tmWakeUp,A0)		CLR.L	(tmReserved,A0)		MOVE.L	A5,(tmRefCon,A0)		_InsXTime		MOVE.L	#25,D0		_PrimeTime		LEA	(timer1,A5),A0		LEA	Timer1Task,A1		MOVE.L	A1,(tmAddr,A0)		CLR.L	(tmCount,A0)		CLR.L	(tmWakeUp,A0)		CLR.L	(tmReserved,A0)		MOVE.L	A5,(tmRefCon,A0)		_InsXTime		MOVE.L	#195,D0		_PrimeTime		RTS		ENDP;ččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččč; pascal void StopTimers(void);;čččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččSTOPTIMERS	PROC	ENTRY		WITH	Globals		LEA	(timer0,A5),A0		_RmvTime		LEA	(timer1,A5),A0		_RmvTime		RTS		ENDP;ččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččč; pascal void InitOPTable(void);;čččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččINITOPTABLE	PROC	ENTRY		WITH	Globals		MOVE.L	#65536*4,D0		_NewPtr		BNE	Error		MOVE.L	A0,(opTable,A5)		MOVEQ	#0,D2@0		CMP.B	#$CB,D2		BNE.S	@2		MOVEQ	#0,D1@1		MOVE	(OPCBxx,PC,D1*2),D0		LEA	(OPCBxx,PC,D0),A1		MOVE.L	A1,(A0)+		ADDQ.B	#1,D1		BCC.S	@1		BRA.S	@10@2		CMP.B	#$DD,D2		BNE.S	@4		MOVEQ	#0,D1@3		MOVE	(OPDDxx,PC,D1*2),D0		LEA	(OPDDxx,PC,D0),A1		MOVE.L	A1,(A0)+		ADDQ.B	#1,D1		BCC.S	@3		BRA.S	@10@4		CMP.B	#$ED,D2		BNE.S	@6		MOVEQ	#0,D1@5		MOVE	(OPEDxx,PC,D1*2),D0		LEA	(OPEDxx,PC,D0),A1		MOVE.L	A1,(A0)+		ADDQ.B	#1,D1		BCC.S	@5		BRA.S	@10@6		CMP.B	#$FD,D2		BNE.S	@8		MOVEQ	#0,D1@7		MOVE	(OPFDxx,PC,D1*2),D0		LEA	(OPFDxx,PC,D0),A1		MOVE.L	A1,(A0)+		ADDQ.B	#1,D1		BCC.S	@7		BRA.S	@10@8		MOVE	(OPxx,PC,D2*2),D0		LEA	(OPxx,PC,D0),A1		MOVE	#256-1,D1@9		MOVE.L	A1,(A0)+		DBRA	D1,@9@10		ADDQ.B	#1,D2		BCC	@0		MOVE.L	(opTable,A5),A0		LEA	(OP3D27,PC),A1		MOVE.L	A1,($3D27*4,A0)		LEA	(OP8027,PC),A1		MOVE.L	A1,($8027*4,A0)		LEA	(OP8127,PC),A1		MOVE.L	A1,($8127*4,A0)		LEA	(OP8527,PC),A1		MOVE.L	A1,($8527*4,A0)		LEA	(OP8727,PC),A1		MOVE.L	A1,($8727*4,A0)		LEA	(OP8C27,PC),A1		MOVE.L	A1,($8C27*4,A0)		LEA	(OPB727,PC),A1		MOVE.L	A1,($B727*4,A0)		LEA	(OPFBC9,PC),A1		MOVE.L	A1,($FBC9*4,A0)Exit		RTSError		_ExitToShell		ENDP;ččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččč; pascal void InitMemory(short romID);;čččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččINITMEMORY	PROC	ENTRYMEMSize		EQU	64*1024ROMSize		EQU	12*1024RAMSize		EQU	48*1024StackFrame	RECORD	{A6Link},DECRParamBegin	EQU	*romID		DS.W	1ParamSize	EQU	ParamBegin-*RetAddr		DS.L	1A6Link		DS.L	1LocalSize	EQU	*		ENDR		WITH	Globals,StackFrame		LINK	A6,#LocalSize		MOVEM.L	D3-D7/A2-A4,-(SP)		MOVE.L	#MEMSize+4,D0		_NewPtr		BNE	Error		MOVE.L	A0,(memory,A5)		SUBQ.L	#4,SP		MOVE.L	#'ROM ',-(SP)		MOVE	(romID,A6),-(SP)		_Get1Resource		MOVE.L	(SP)+,D0		BEQ.S	Error		MOVE.L	D0,A2		MOVE.L	(A2),A0		MOVE.L	(memory,A5),A1		MOVE.L	#ROMSize,D0		_BlockMoveData		BNE.S	Error		MOVE.L	A2,-(SP)		_ReleaseResource		MOVE.L	(memory,A5),A0		; ROM		ADD	#ROMSize,A0		MOVE	#2048/4-1,D1		; hardware		MOVEQ	#-1,D0@0		MOVE.L	D0,(A0)+		DBRA	D1,@0		MOVE	#1024/4-1,D1		; keyboard		MOVEQ	#0,D0@1		MOVE.L	D0,(A0)+		DBRA	D1,@1		MOVE.L	A0,(screen,A5)		; screen		MOVE	#1024/4-1,D1		MOVE.L	#$20202020,D0@2		MOVE.L	D0,(A0)+		DBRA	D1,@2		MOVE	#RAMSize/128-1,D2	; RAM@3		MOVE	#64/4-1,D1		MOVEQ	#-1,D0@4		MOVE.L	D0,(A0)+		DBRA	D1,@4		MOVE	#64/4-1,D1		MOVEQ	#0,D0@5		MOVE.L	D0,(A0)+		DBRA	D1,@5		DBRA	D2,@3		CLR.L	(A0)+		MOVE.B	#$3F,(IntLatch,A5)Exit		MOVEM.L	(SP)+,D3-D7/A2-A4		UNLK	A6		RTD	#ParamSizeError		_ExitToShell		ENDP;ččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččč; pascal void InitLogic(void);;čččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččččINITLOGIC	PROC	ENTRY		WITH	Globals		LEA	(ANDFlags,A5),A1		LEA	(XORFlags,A5),A0		MOVEQ	#0,D3@0		MOVEQ	#%00000100,D2		MOVE.B	D3,D1		BEQ.S	@2@1		EOR.B	#%00000100,D2		MOVE.B	D1,D0		SUBQ.B	#1,D0		AND.B	D0,D1		BNE.S	@1@2		TST.B	D3		BPL.S	