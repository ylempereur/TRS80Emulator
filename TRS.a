;———————————————————————————————————————————————————————————————
OLDROUTINENAMES         EQU     1
;———————————————————————————————————————————————————————————————
                PRINT   PUSH,OFF

                INCLUDE 'MacTypes.a'
                INCLUDE 'Timer.a'
                INCLUDE 'LowMemEqu.a'
                INCLUDE 'Processes.a'
                INCLUDE 'Resources.a'

                PRINT   POP
;———————————————————————————————————————————————————————————————
NIL             EQU     0
;———————————————————————————————————————————————————————————————
Z80             RECORD  0

AF#             DS.W    1
BC#             DS.W    1
DE#             DS.W    1
HL#             DS.W    1

AF              EQU     *
A               DS.B    1
F               DS.B    1

BC              EQU     *
B               DS.B    1
C               DS.B    1

DE              EQU     *
D               DS.B    1
E               DS.B    1

HL              EQU     *
H               DS.B    1
L               DS.B    1

                DS.B    1
I               DS.B    1

IC              EQU     *
                DS.B    1
R               DS.B    1

IX              DS.W    1
IY              DS.W    1
SP              DS.W    1
PC              DS.W    1

sizeof          EQU     *
                ENDR
;———————————————————————————————————————————————————————————————
TMInfo          RECORD  0
task            DS      TMTask
tmRefCon        DS.L    1
sizeof          EQU     *
                ENDR
;———————————————————————————————————————————————————————————————
Globals         RECORD  0               ; TRS object

diskBuff        DS.L    2
diskSize        DS.L    2
diskRefNum      DS.W    2
diskProtect     DS.B    2
diskDirty       DS.B    2
screen          DS.L    1
driveTime       DS.L    1
driveSelect     DS.B    1
cassette        DS.B    1

                DS.B    2

ANDFlags        DS.B    256
XORFlags        DS.B    256
ORFlags         EQU     XORFlags
reg             DS      Z80
timer0          DS      TMInfo
timer1          DS      TMInfo
macKeys         DS.W    8
trsKeys         DS.B    8
opTable         DS.L    1
memory          DS.L    1
ICount          DS.L    1
RWPtr           DS.L    1
RWCount         DS.W    1
numKeys         DS.W    1
INTMaster       DS.B    1
IFF1            DS.B    1
IFF2            DS.B    1
Z80NMIFlag      DS.B    1
Z80INTFlag      DS.B    1
IntLatch        DS.B    1
diskIndex       DS.B    1
FDCState        DS.B    1
FDCFlags        DS.B    1
FDCTrack        DS.B    1
FDCSector       DS.B    1
FDCData         DS.B    1

GlobalSize      EQU     *
                ENDR
;———————————————————————————————————————————————————————————————
                MACHINE MC68020
;———————————————————————————————————————————————————————————————
; Resource Header
;———————————————————————————————————————————————————————————————
                MAIN    ENTRY

                IMPORT  Dispatch

                BRA.S   Dispatch        ; enter here
                DC.W    0               ; filler
                DC.L    ('TRS ')        ; type
                DC.W    128             ; ID
                DC.W    $0160           ; version

                ENDMAIN
;———————————————————————————————————————————————————————————————
; Routine name  Dispatch
;———————————————————————————————————————————————————————————————
Dispatch        PROC    ENTRY

                IMPORT  TRSNew,TRSDispose,TRSSwapROM,TRSReset,TRSNMI,TRSRun
                IMPORT  TRSKeyDown,TRSKeyUp

                MOVE    (@0,PC,D0*2),D0
                JMP     (@0,PC,D0)
@0              DC.W    TRSNew-@0
                DC.W    TRSDispose-@0
                DC.W    TRSSwapROM-@0
                DC.W    TRSReset-@0
                DC.W    TRSNMI-@0
                DC.W    TRSRun-@0
                DC.W    TRSKeyDown-@0
                DC.W    TRSKeyUp-@0

                ENDP
;———————————————————————————————————————————————————————————————
; Z80 Emulator
;———————————————————————————————————————————————————————————————
Z80Emulator     PROC    ENTRY

                IMPORT  MEMRead,MEMWrite

                ENTRY   NMI,INT
                ENTRY   OPxx,OPCBxx,OPDDxx,OPEDxx,OPFDxx
                ENTRY   OP8027,OP8127,OP8527,OP8727,OP8C27
                ENTRY   OP3D27,OPB727,OPFBC9

                WITH    Globals
;———————————————————————————————————————————————————————————————
; Routine name  NMI
;———————————————————————————————————————————————————————————————
NMI             SF      (IFF1,A5)
                SF      (Z80INTFlag,A5)
                SF      (Z80NMIFlag,A5)
                ROR     #8,D7
                SUBQ    #2,D6
                MOVE    D7,(A4,D6.L)
                MOVEQ   #$0066,D7
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; Routine name  INT
;———————————————————————————————————————————————————————————————
INT             SUBQ.L  #1,(ICount,A5)
                SF      (IFF1,A5)
                SF      (IFF2,A5)
                SF      (Z80INTFlag,A5)
                ROR     #8,D7
                SUBQ    #2,D6
                MOVE    D7,(A4,D6.L)
                MOVEQ   #$0038,D7
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; Unimplemented Instruction
;———————————————————————————————————————————————————————————————
Unimp           JMP     (A0)
;———————————————————————————————————————————————————————————————
; NOP
;———————————————————————————————————————————————————————————————
OP00            ADDQ    #1,D7
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; LD BC,nn
;———————————————————————————————————————————————————————————————
OP01            MOVE    (1,A4,D7.L),D0
                ADDQ    #3,D7
                ROR     #8,D0
                MOVE    D0,(reg.BC,A5)
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; LD (BC),A
;———————————————————————————————————————————————————————————————
OP02            ADDQ    #1,D7
                MOVE    (reg.BC,A5),D1
                CMP     #$3C00,D1
                BLO.S   @0
                MOVE.B  D4,(A4,D1.L)
                JMP     (A0)
@0              CMP     #$37DE,D1
                BLO.S   @1
                MOVE.B  D4,D0
                BSR     MEMWrite
@1              JMP     (A0)
;———————————————————————————————————————————————————————————————
; INC BC
;———————————————————————————————————————————————————————————————
OP03            ADDQ    #1,D7
                ADDQ    #1,(reg.BC,A5)
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; INC B
;———————————————————————————————————————————————————————————————
OP04            ADDQ    #1,D7
                AND.B   #%00000001,D5
                ADDQ.B  #1,(reg.B,A5)
                MOVE    CCR,D3
                OR.B    (INCFlags,PC,D3),D5
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; DEC B
;———————————————————————————————————————————————————————————————
OP05            ADDQ    #1,D7
                AND.B   #%00000001,D5
                SUBQ.B  #1,(reg.B,A5)
                MOVE    CCR,D3
                OR.B    (DECFlags,PC,D3),D5
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; LD B,n
;———————————————————————————————————————————————————————————————
OP06            ADDQ    #2,D7
                MOVE.B  D0,(reg.B,A5)
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; RLCA
;———————————————————————————————————————————————————————————————
OP07            ADDQ    #1,D7
                AND.B   #%11000100,D5
                ROL.B   #1,D4
                MOVE    CCR,D3
                AND.B   #%00000001,D3
                OR.B    D3,D5
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; EX AF,AF'
;———————————————————————————————————————————————————————————————
OP08            ADDQ    #1,D7
                MOVE.B  D4,D0
                ROR     #8,D0
                MOVE.B  D5,D0
                MOVE    (reg.AF#,A5),D1
                MOVE    D0,(reg.AF#,A5)
                MOVE.B  D1,D5
                ROR     #8,D1
                MOVE.B  D1,D4
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; ADD HL,BC
;———————————————————————————————————————————————————————————————
OP09            ADDQ    #1,D7
                AND.B   #%11000100,D5
                MOVE    (reg.BC,A5),D0
                ADD     D0,(reg.HL,A5)
                MOVE    CCR,D3
                OR.B    (ADWFlags,PC,D3),D5
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; LD A,(BC)
;———————————————————————————————————————————————————————————————
OP0A            ADDQ    #1,D7
                MOVE    (reg.BC,A5),D1
                CMP     #$3C00,D1
                BLO.S   @0
                MOVE.B  (A4,D1.L),D4
                JMP     (A0)
@0              CMP     #$37DE,D1
                BHS.S   @1
                MOVE.B  (A4,D1.L),D4
                JMP     (A0)
@1              BSR     MEMRead
                MOVE.B  D0,D4
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; DEC BC
;———————————————————————————————————————————————————————————————
OP0B            ADDQ    #1,D7
                SUBQ    #1,(reg.BC,A5)
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; INC C
;———————————————————————————————————————————————————————————————
OP0C            ADDQ    #1,D7
                AND.B   #%00000001,D5
                ADDQ.B  #1,(reg.C,A5)
                MOVE    CCR,D3
                OR.B    (INCFlags,PC,D3),D5
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; DEC C
;———————————————————————————————————————————————————————————————
OP0D            ADDQ    #1,D7
                AND.B   #%00000001,D5
                SUBQ.B  #1,(reg.C,A5)
                MOVE    CCR,D3
                OR.B    (DECFlags,PC,D3),D5
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; LD C,n
;———————————————————————————————————————————————————————————————
OP0E            ADDQ    #2,D7
                MOVE.B  D0,(reg.C,A5)
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; RRCA
;———————————————————————————————————————————————————————————————
OP0F            ADDQ    #1,D7
                AND.B   #%11000100,D5
                ROR.B   #1,D4
                MOVE    CCR,D3
                AND.B   #%00000001,D3
                OR.B    D3,D5
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; DJNZ e
;———————————————————————————————————————————————————————————————
OP10            ADDQ    #2,D7
                SUBQ.B  #1,(reg.B,A5)
                BEQ.S   @0
                EXT     D0
                ADD     D0,D7
@0              JMP     (A0)
;———————————————————————————————————————————————————————————————
; LD DE,nn
;———————————————————————————————————————————————————————————————
OP11            MOVE    (1,A4,D7.L),D0
                ADDQ    #3,D7
                ROR     #8,D0
                MOVE    D0,(reg.DE,A5)
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; LD (DE),A
;———————————————————————————————————————————————————————————————
OP12            ADDQ    #1,D7
                MOVE    (reg.DE,A5),D1
                CMP     #$3C00,D1
                BLO.S   @0
                MOVE.B  D4,(A4,D1.L)
                JMP     (A0)
@0              CMP     #$37DE,D1
                BLO.S   @1
                MOVE.B  D4,D0
                BSR     MEMWrite
@1              JMP     (A0)
;———————————————————————————————————————————————————————————————
; INC DE
;———————————————————————————————————————————————————————————————
OP13            ADDQ    #1,D7
                ADDQ    #1,(reg.DE,A5)
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; INC D
;———————————————————————————————————————————————————————————————
OP14            ADDQ    #1,D7
                AND.B   #%00000001,D5
                ADDQ.B  #1,(reg.D,A5)
                MOVE    CCR,D3
                OR.B    (INCFlags,PC,D3),D5
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; DEC D
;———————————————————————————————————————————————————————————————
OP15            ADDQ    #1,D7
                AND.B   #%00000001,D5
                SUBQ.B  #1,(reg.D,A5)
                MOVE    CCR,D3
                OR.B    (DECFlags,PC,D3),D5
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; LD D,n
;———————————————————————————————————————————————————————————————
OP16            ADDQ    #2,D7
                MOVE.B  D0,(reg.D,A5)
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; RLA
;———————————————————————————————————————————————————————————————
OP17            ADDQ    #1,D7
                AND.B   #%11000101,D5
                LSR.B   #1,D5
                ROXL.B  #1,D4
                ROXL.B  #1,D5
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; JR e
;———————————————————————————————————————————————————————————————
OP18            ADDQ    #2,D7
                EXT     D0
                ADD     D0,D7
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; ADD HL,DE
;———————————————————————————————————————————————————————————————
OP19            ADDQ    #1,D7
                AND.B   #%11000100,D5
                MOVE    (reg.DE,A5),D0
                ADD     D0,(reg.HL,A5)
                MOVE    CCR,D3
                OR.B    (ADWFlags,PC,D3),D5
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; LD A,(DE)
;———————————————————————————————————————————————————————————————
OP1A            ADDQ    #1,D7
                MOVE    (reg.DE,A5),D1
                CMP     #$3C00,D1
                BLO.S   @0
                MOVE.B  (A4,D1.L),D4
                JMP     (A0)
@0              CMP     #$37DE,D1
                BHS.S   @1
                MOVE.B  (A4,D1.L),D4
                JMP     (A0)
@1              BSR     MEMRead
                MOVE.B  D0,D4
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; DEC DE
;———————————————————————————————————————————————————————————————
OP1B            ADDQ    #1,D7
                SUBQ    #1,(reg.DE,A5)
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; INC E
;———————————————————————————————————————————————————————————————
OP1C            ADDQ    #1,D7
                AND.B   #%00000001,D5
                ADDQ.B  #1,(reg.E,A5)
                MOVE    CCR,D3
                OR.B    (INCFlags,PC,D3),D5
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; DEC E
;———————————————————————————————————————————————————————————————
OP1D            ADDQ    #1,D7
                AND.B   #%00000001,D5
                SUBQ.B  #1,(reg.E,A5)
                MOVE    CCR,D3
                OR.B    (DECFlags,PC,D3),D5
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; LD E,n
;———————————————————————————————————————————————————————————————
OP1E            ADDQ    #2,D7
                MOVE.B  D0,(reg.E,A5)
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; RRA
;———————————————————————————————————————————————————————————————
OP1F            ADDQ    #1,D7
                AND.B   #%11000101,D5
                LSR.B   #1,D5
                ROXR.B  #1,D4
                ROXL.B  #1,D5
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; JR NZ,e
;———————————————————————————————————————————————————————————————
OP20            ADDQ    #2,D7
                BTST    #6,D5
                BNE.S   @0
                EXT     D0
                ADD     D0,D7
@0              JMP     (A0)
;———————————————————————————————————————————————————————————————
; LD HL,nn
;———————————————————————————————————————————————————————————————
OP21            MOVE    (1,A4,D7.L),D0
                ADDQ    #3,D7
                ROR     #8,D0
                MOVE    D0,(reg.HL,A5)
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; LD (nn),HL
;———————————————————————————————————————————————————————————————
OP22            MOVE    (1,A4,D7.L),D1
                ADDQ    #3,D7
                ROR     #8,D1
                MOVE    (reg.HL,A5),D0
                ROR     #8,D0
                MOVE    D0,(A4,D1.L)
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; INC HL
;———————————————————————————————————————————————————————————————
OP23            ADDQ    #1,D7
                ADDQ    #1,(reg.HL,A5)
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; INC H
;———————————————————————————————————————————————————————————————
OP24            ADDQ    #1,D7
                AND.B   #%00000001,D5
                ADDQ.B  #1,(reg.H,A5)
                MOVE    CCR,D3
                OR.B    (INCFlags,PC,D3),D5
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; DEC H
;———————————————————————————————————————————————————————————————
OP25            ADDQ    #1,D7
                AND.B   #%00000001,D5
                SUBQ.B  #1,(reg.H,A5)
                MOVE    CCR,D3
                OR.B    (DECFlags,PC,D3),D5
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; LD H,n
;———————————————————————————————————————————————————————————————
OP26            ADDQ    #2,D7
                MOVE.B  D0,(reg.H,A5)
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; DAA
;———————————————————————————————————————————————————————————————
OP27            JMP     (A0)

                ADDQ    #1,D7
                PEA     #'*** DAA ***'
                _DebugStr
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; JR Z,e
;———————————————————————————————————————————————————————————————
OP28            ADDQ    #2,D7
                BTST    #6,D5
                BEQ.S   @0
                EXT     D0
                ADD     D0,D7
@0              JMP     (A0)
;———————————————————————————————————————————————————————————————
; ADD HL,HL
;———————————————————————————————————————————————————————————————
OP29            ADDQ    #1,D7
                AND.B   #%11000100,D5
                MOVE    (reg.HL,A5),D0
                ADD     D0,(reg.HL,A5)
                MOVE    CCR,D3
                OR.B    (ADWFlags,PC,D3),D5
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; LD HL,(nn)
;———————————————————————————————————————————————————————————————
OP2A            MOVE    (1,A4,D7.L),D1
                ADDQ    #3,D7
                ROR     #8,D1
                MOVE    (A4,D1.L),D0
                ROR     #8,D0
                MOVE    D0,(reg.HL,A5)
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; DEC HL
;———————————————————————————————————————————————————————————————
OP2B            ADDQ    #1,D7
                SUBQ    #1,(reg.HL,A5)
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; INC L
;———————————————————————————————————————————————————————————————
OP2C            ADDQ    #1,D7
                AND.B   #%00000001,D5
                ADDQ.B  #1,(reg.L,A5)
                MOVE    CCR,D3
                OR.B    (INCFlags,PC,D3),D5
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; DEC L
;———————————————————————————————————————————————————————————————
OP2D            ADDQ    #1,D7
                AND.B   #%00000001,D5
                SUBQ.B  #1,(reg.L,A5)
                MOVE    CCR,D3
                OR.B    (DECFlags,PC,D3),D5
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; LD L,n
;———————————————————————————————————————————————————————————————
OP2E            ADDQ    #2,D7
                MOVE.B  D0,(reg.L,A5)
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; CPL
;———————————————————————————————————————————————————————————————
OP2F            ADDQ    #1,D7
                AND.B   #%11000101,D5
                NOT.B   D4
                OR.B    #%00010010,D5
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; JR NC,e
;———————————————————————————————————————————————————————————————
OP30            ADDQ    #2,D7
                BTST    #0,D5
                BNE.S   @0
                EXT     D0
                ADD     D0,D7
@0              JMP     (A0)
;———————————————————————————————————————————————————————————————
; LD SP,nn
;———————————————————————————————————————————————————————————————
OP31            MOVE    (1,A4,D7.L),D6
                ADDQ    #3,D7
                ROR     #8,D6
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; LD (nn),A
;———————————————————————————————————————————————————————————————
OP32            MOVE    (1,A4,D7.L),D1
                ADDQ    #3,D7
                ROR     #8,D1
                CMP     #$3C00,D1
                BLO.S   @0
                MOVE.B  D4,(A4,D1.L)
                JMP     (A0)
@0              CMP     #$37DE,D1
                BLO.S   @1
                MOVE.B  D4,D0
                BSR     MEMWrite
@1              JMP     (A0)
;———————————————————————————————————————————————————————————————
; INC SP
;———————————————————————————————————————————————————————————————
OP33            ADDQ    #1,D7
                ADDQ    #1,D6
                JMP     (A0)
;———————————————————————————————————————————————————————————————
; INC (HL)
;———————————————————————————————————————————————————————————————
OP34            ADDQ    #1,D7
                AND.B   #%00000001,D5
                MOVE    (reg.HL,A5),D1
                CMP     #$3C00,D1
                BLO.S   @0
                ADDQ.B  #1,(A4,D1.L)
                MOVE    CCR,D3
                OR.B    (INCFlags,PC,D3),D5
                JMP     (A0)
@0              CMP     #$37DE,D1
                BHS.S   @1
                MOVE.B  (A4,D1.L),D0
                ADDQ.B  #1,D0
                MOVE    CCR,D3
                OR.B    (INCFlags,PC,D3),D5
                JMP     (A0)
@1              BSR     MEMRead
                ADDQ.B  #1,D0
                MOVE    CCR,D3
                OR.B    (INCFlags,PC,D3),D5
                BSR     MEMWrite
                JMP     (A0)
;———————————————————————————————————————————————————————————————
